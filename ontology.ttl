    rdfs:range  xsd:decimal .

ein:distCafeteria a rdf:Property ;
    rdfs:label "distance to cafeteria (km)" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:distRestaurant a rdf:Property ;
    rdfs:label "distance to restaurant (km)" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:distSwimmingPool a rdf:Property ;
    rdfs:label "distance to swimming pool (km)" ;
    rdfs:domain ein:Observation ;
