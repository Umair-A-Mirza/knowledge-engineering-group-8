ein:distSupermarket a rdf:Property ;
    rdfs:label "distance to supermarket (km)" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:distDailyGroceries a rdf:Property ;
    rdfs:label "distance to daily groceries (km)" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

