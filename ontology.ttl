@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ein:  <http://eindhoven.nl/livability/> .

# Classes ---------------------------------------------------------------------------------------

ein:Neighborhood a rdfs:Class ;
    rdfs:label "Neighborhood" ;
    rdfs:comment "A recognized neighborhood within the municipality of Eindhoven." .

ein:Observation a rdfs:Class ;
    rdfs:label "Observation" ;
    rdfs:comment "A set of livability indicators recorded for one neighborhood in one year." .

# Properties ----------------------------------------------------------------------------------------

ein:hasObservation a rdf:Property ;
    rdfs:label "has observation" ;
    rdfs:domain ein:Neighborhood ;
    rdfs:range  ein:Observation .

ein:inNeighborhood a rdf:Property ;
    rdfs:label "in neighborhood" ;
    rdfs:domain ein:Observation ;
    rdfs:range  ein:Neighborhood .

# Join Key ----------------------------------------------------------------------------------------

ein:hasName a rdf:Property ;
    rdfs:label "name" ;
    rdfs:domain ein:Neighborhood ;
    rdfs:range  xsd:string .

ein:inYear a rdf:Property ;
    rdfs:label "year" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:integer .

# Leefbaarometer ---------------------------------------------------------------------------------------- 

ein:livabilityScore a rdf:Property ;
    rdfs:label "livability score" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:livabilityDeviation a rdf:Property ;
    rdfs:label "deviation from national average" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:physicalEnvironmentDeviation a rdf:Property ;
    rdfs:label "physical environment sub-dimension deviation" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:nuisanceInsecurityDeviation a rdf:Property ;
    rdfs:label "nuisance and insecurity sub-dimension deviation" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:socialCohesionDeviation a rdf:Property ;
    rdfs:label "social cohesion sub-dimension deviation" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:facilitiesDeviation a rdf:Property ;
    rdfs:label "facilities sub-dimension deviation" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:housingStockDeviation a rdf:Property ;
    rdfs:label "housing stock sub-dimension deviation" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

