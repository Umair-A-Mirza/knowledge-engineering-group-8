# Housing Stock ---------------------------------------------------------------------------------------

ein:rentalDwellings a rdf:Property ;
    rdfs:label "proportion of rental dwellings" ;
    rdfs:comment "Share of dwellings that are rental, expressed as a decimal between 0 and 1." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:ownerOccupiedDwellings a rdf:Property ;
    rdfs:label "proportion of owner-occupied dwellings" ;
    rdfs:comment "Share of dwellings that are owner-occupied, expressed as a decimal between 0 and 1." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:corporationDwellings a rdf:Property ;
    rdfs:label "proportion of corporation dwellings" ;
    rdfs:comment "Share of dwellings owned by housing corporations, expressed as a decimal between 0 and 1." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:totalDwellings a rdf:Property ;
    rdfs:label "total number of dwellings" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:integer .

ein:pctOccupied a rdf:Property ;
    rdfs:label "percentage of dwellings occupied, expressed as a decimal between 0 and 1." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:avgWozValue a rdf:Property ;
    rdfs:label "average WOZ property value (euro thousands)" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

# Nuisance and Safety ---------------------------------------------------------------------------------------- 

ein:pctFeelsUnsafe a rdf:Property ;
    rdfs:label "percentage feeling unsafe, expressed as a decimal between 0 and 1." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:pctPerceivesCrime a rdf:Property ;
    rdfs:label "percentage perceiving high crime, expressed as a decimal between 0 and 1." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:safetyRating a rdf:Property ;
    rdfs:label "resident safety rating" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:pctNoiseRoadTraffic a rdf:Property ;
    rdfs:label "percentage disturbed by road traffic noise, expressed as a decimal between 0 and 1." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:pctNoiseRailTraffic a rdf:Property ;
    rdfs:label "percentage disturbed by rail traffic noise, expressed as a decimal between 0 and 1." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:pctNoiseAirTraffic a rdf:Property ;
    rdfs:label "percentage disturbed by air traffic noise, expressed as a decimal between 0 and 1." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:pctNoiseBusiness a rdf:Property ;
    rdfs:label "percentage disturbed by business noise, expressed as a decimal between 0 and 1." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:pctNoiseEvents a rdf:Property ;
    rdfs:label "percentage disturbed by event noise, expressed as a decimal between 0 and 1." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:pctNoiseNeighbors a rdf:Property ;
    rdfs:label "percentage disturbed by neighbor noise, expressed as a decimal between 0 and 1." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:pctPollutedAir a rdf:Property ;
    rdfs:label "percentage experiencing polluted air, expressed as a decimal between 0 and 1." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:pctBadSmell a rdf:Property ;
    rdfs:label "percentage experiencing bad smell, expressed as a decimal between 0 and 1." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:pctAnyNoise a rdf:Property ;
    rdfs:label "percentage experiencing any noise nuisance, expressed as a decimal between 0 and 1." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

# Physical Environment ---------------------------------------------------------------------------------------- 

ein:addressDensity a rdf:Property ;
    rdfs:label "address density (addresses per km²)" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:integer .

ein:urbanityClass a rdf:Property ;
    rdfs:label "CBS urbanity class" ;
    rdfs:comment "Urbanity classification assigned by CBS: Very strongly urban, Strongly urban, Moderately urban, Slightly urban, or Not urban." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:string .

ein:areaWaterHa a rdf:Property ;
    rdfs:label "water surface area (hectares)" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:areaLandHa a rdf:Property ;
    rdfs:label "land surface area (hectares)" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:areaTotalHa a rdf:Property ;
    rdfs:label "total surface area (hectares)" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

# Social Cohesion ----------------------------------------------------------------------------------------- 

ein:cohesionScaleScore a rdf:Property ;
    rdfs:label "social cohesion scale score" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:pctActivelyEngaged a rdf:Property ;
    rdfs:label "percentage actively engaged in neighborhood, expressed as a decimal between 0 and 1." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:pctWantsToEngage a rdf:Property ;
    rdfs:label "percentage wanting to engage in future, expressed as a decimal between 0 and 1." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:pctMaybeEngage a rdf:Property ;
    rdfs:label "percentage possibly wanting to engage in future, expressed as a decimal between 0 and 1." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

# Population ----------------------------------------------------------------------------------------- 

ein:population a rdf:Property ;
    rdfs:label "total population count" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:integer .

# Flags ----------------------------------------------------------------------------------------- 

ein:dimensionScoresAvailable a rdf:Property ;
    rdfs:label "dimension scores available" ;
    rdfs:comment "True if Leefbaarometer 3.0 sub-dimension scores were computed for this year." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:boolean .

ein:surveyAvailable a rdf:Property ;
    rdfs:label "survey available" ;
    rdfs:comment "True if Nuisance and Safety perception survey indicators are present for this year." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:boolean .

ein:engagementAvailable a rdf:Property ;
    rdfs:label "engagement available" ;
    rdfs:comment "True if Social Cohesion engagement percentage indicators are present for this year." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:boolean .

ein:wozAvailable a rdf:Property ;
    rdfs:label "WOZ value available" ;
    rdfs:comment "True if the WOZ property value is available for this neighborhood-year." ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:boolean .