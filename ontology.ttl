    rdfs:range  xsd:decimal .

ein:distLibrary a rdf:Property ;
    rdfs:label "distance to library (km)" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:distMuseum a rdf:Property ;
    rdfs:label "distance to museum (km)" ;
    rdfs:domain ein:Observation ;
