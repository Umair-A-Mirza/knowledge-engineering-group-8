ein:distCinema a rdf:Property ;
    rdfs:label "distance to cinema (km)" ;
    rdfs:domain ein:Observation ;
    rdfs:range  xsd:decimal .

ein:distAttraction a rdf:Property ;
    rdfs:label "distance to attraction (km)" ;
